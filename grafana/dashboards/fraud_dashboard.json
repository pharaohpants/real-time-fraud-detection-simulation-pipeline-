        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT rule_name, COUNT(*) AS trigger_count\nFROM (\n  SELECT 'VELOCITY'          AS rule_name FROM fraud_flags WHERE is_velocity          AND processed_at > NOW() - INTERVAL '24 hours'\n  UNION ALL\n  SELECT 'IMPOSSIBLE_TRAVEL' AS rule_name FROM fraud_flags WHERE is_impossible_travel AND processed_at > NOW() - INTERVAL '24 hours'\n  UNION ALL\n  SELECT 'AMOUNT_SPIKE'      AS rule_name FROM fraud_flags WHERE is_amount_spike      AND processed_at > NOW() - INTERVAL '24 hours'\n  UNION ALL\n  SELECT 'OFF_HOURS'         AS rule_name FROM fraud_flags WHERE is_off_hours         AND processed_at > NOW() - INTERVAL '24 hours'\n  UNION ALL\n  SELECT 'CARD_TESTING'      AS rule_name FROM fraud_flags WHERE is_card_testing      AND processed_at > NOW() - INTERVAL '24 hours'\n) sub\nGROUP BY rule_name\nORDER BY trigger_count DESC",
          "refId": "A"
        }
      ],
      "title": "Rule Paling Sering Aktif (24h)",
